{
  "compilerOptions": {
    "target": "ES2017",
    "baseUrl": ".",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["app/*"],
      "@components/*": ["app/(frontend)/shared/components/*"],
      "@constants/*": ["app/(frontend)/shared/constants/*"],
      "@slides/*": ["app/(frontend)/shared/slides/*"],
      "@utils/*": ["app/(frontend)/shared/utils/*"],
      "@hooks/*": ["app/(frontend)/shared/hooks/*"],
      "@services/*": ["app/(frontend)/shared/services/*"],

      "@models/*" : ["app/(backend)/models/*"],
      "@schemas/*" : ["app/(backend)/schemas/*"],
      "@errors/*" : ["app/(backend)/errors/*"],
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
, "server/app.js"  ],
  "exclude": ["node_modules"]
}
